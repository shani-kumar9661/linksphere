# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database Configuration
# In Docker, change localhost to mongodb (container name)
MONGODB_URI=mongodb://localhost:27017/linksphere

# Caching Configuration
# In Docker, change localhost to redis (container name)
REDIS_URL=redis://localhost:6379

# Authentication Secrets
# Generate secure keys using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_access_token_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_here

# Token Expirations
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Verification & Reset Configuration (SMTP)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@linksphere.com
